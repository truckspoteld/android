<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/dark_card_background"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/dark_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvDvirHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pre Trip • 2026-02-25"
            android:textColor="@color/dark_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDvirVehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Vehicle: VIN123"
            android:textColor="@color/dark_text_secondary" />

        <TextView
            android:id="@+id/tvDvirCondition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Condition: Satisfactory"
            android:textColor="@color/dark_text_secondary" />

        <TextView
            android:id="@+id/tvDvirStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Status: submitted"
            android:textColor="@color/blue" />

        <TextView
            android:id="@+id/tvDvirDefects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Defects: -"
            android:textColor="@color/dark_text_secondary" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
