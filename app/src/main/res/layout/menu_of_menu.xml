<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#F2F2F7"
    app:cardCornerRadius="14dp"
    app:cardElevation="8dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#C6C6C8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:divider="@drawable/divider_horizontal_ios"
        android:showDividers="middle">

        <TextView
            android:id="@+id/option1"
            style="@style/IosMenuItemStyle"
            android:text="30 minutes break" />

        <TextView
            android:id="@+id/option2"
            style="@style/IosMenuItemStyle"
            android:text="week reset" />

        <TextView
            android:id="@+id/option3"
            style="@style/IosMenuItemStyle"
            android:text="out of service" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
