<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/strockColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvDvirHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pre Trip • 2026-02-25"
                android:textColor="@color/home_text_main"
                android:textSize="14sp"
                android:fontFamily="@font/sf_pro_display_bold" />

            <TextView
                android:id="@+id/tvDvirStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Submitted"
                android:textColor="@color/status_on_text"
                android:textSize="12sp"
                android:fontFamily="@font/sf_pro_display_bold"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#DEF7ED"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle"
                    android:textColor="@color/home_text_sub"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvDvirVehicle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIN123"
                    android:textColor="@color/home_text_main"
                    android:fontFamily="@font/sf_pro_display_medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Condition"
                    android:textColor="@color/home_text_sub"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvDvirCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satisfactory"
                    android:textColor="@color/home_text_main"
                    android:fontFamily="@font/sf_pro_display_medium" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDvirDefects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Defects: None"
            android:textColor="@color/home_text_sub"
            android:textSize="13sp"
            android:fontFamily="@font/sf_pro_display_regular"
            android:background="#F8FAFC"
            android:padding="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
