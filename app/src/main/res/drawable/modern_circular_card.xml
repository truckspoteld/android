<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/gauge_shadow_color" />
            <corners android:radius="@dimen/circular_card_corner_radius" />
        </shape>
    </item>
    
    <!-- Card background -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_card_background" />
            <corners android:radius="@dimen/circular_card_corner_radius" />
            <stroke android:width="2dp" android:color="@color/dark_divider" />
        </shape>
    </item>
</layer-list>
