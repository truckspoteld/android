<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Top Border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E293B" /> <!-- Subtle border color for dark theme -->
            <corners
                android:topLeftRadius="@dimen/_10dp"
                android:topRightRadius="@dimen/_10dp" />
        </shape>
    </item>

    <!-- Main Background (offset 1dp from top) -->
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_background" />
            <corners
                android:topLeftRadius="@dimen/_10dp"
                android:topRightRadius="@dimen/_10dp" />
        </shape>
    </item>
</layer-list>