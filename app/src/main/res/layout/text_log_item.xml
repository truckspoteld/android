<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/logTIle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/strockColor"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Vertical Status Indicator -->
        <View
            android:id="@+id/status_indicator"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_log_item_indicator"
            android:backgroundTint="@color/nav_icon_inactive"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Status Pill & Title -->
        <LinearLayout
            android:id="@+id/status_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@id/status_indicator"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/status_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:tag="binding_2"
                android:text="OFF"
                android:textColor="@color/home_text_main"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Off Duty"
                android:textColor="@color/home_text_main"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Meta Info (Location & Distance) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@+id/time_container"
            app:layout_constraintStart_toStartOf="@id/status_header"
            app:layout_constraintTop_toBottomOf="@id/status_header">

            <TextView
                android:id="@+id/location_txt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:tag="binding_3"
                android:text="Los Angeles, CA"
                android:textColor="@color/home_text_sub"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:text="•"
                android:textColor="@color/home_text_sub" />

            <TextView
                android:id="@+id/odo_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tag="binding_4"
                android:text="24.5 mi"
                android:textColor="@color/home_text_sub"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Time Column on Right -->
        <LinearLayout
            android:id="@+id/time_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/time_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tag="binding_1"
                android:text="08:24 PM"
                android:textColor="@color/home_text_main"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/origin_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:tag="binding_6"
                android:text="Auto"
                android:textColor="@color/home_text_sub"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Hidden elements for adapter compatibility -->
        <TextView android:id="@+id/eng_txt" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:tag="binding_5" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>