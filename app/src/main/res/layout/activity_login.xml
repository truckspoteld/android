<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_gradient_new"
    tools:context=".LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_14sdp">

        <!-- Logo Row -->
        <LinearLayout
            android:id="@+id/logoRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/_17sdp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_splash" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Truckspot"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/login_text_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fleet Management"
                    android:textSize="12sp"
                    android:textColor="@color/login_text_gray" />
            </LinearLayout>
        </LinearLayout>

        <!-- Header text -->
        <TextView
            android:id="@+id/welcometext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Control Your Drive Day"
            android:textColor="@color/login_text_dark"
            android:textSize="@dimen/_21sdp"
            android:textStyle="bold"
            android:lineSpacingExtra="-4dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/logoRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/logintext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sign in to monitor logs, shift limits, certification, and DVIR from one command center."
            android:textColor="@color/login_text_gray"
            android:textSize="@dimen/_11sdp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintTop_toBottomOf="@id/welcometext"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Chips -->
        <HorizontalScrollView
            android:id="@+id/chipsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="@dimen/_14sdp"
            app:layout_constraintTop_toBottomOf="@id/logintext">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_white"
                    android:text="Advanced UI"
                    android:textColor="@color/login_text_dark"
                    android:textSize="@dimen/_11sdp"
                    android:textStyle="bold"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:paddingVertical="8dp"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    app:drawableStartCompat="@drawable/ic_sparkles" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_white"
                    android:text="Secure Access"
                    android:textColor="@color/login_text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginStart="12dp"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    app:drawableStartCompat="@drawable/ic_shield_check_new" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_white"
                    android:text="Live Data"
                    android:textColor="@color/login_text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginStart="12dp"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    app:drawableStartCompat="@drawable/ic_activity_new" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Login Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            app:cardCornerRadius="@dimen/_13sdp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="0dp"
            app:strokeColor="@color/strockColor"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/chipsScroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_15dp">

                <TextView
                    android:id="@+id/loginhead"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="@color/login_text_dark"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver credentials"
                    android:textColor="@color/login_text_gray"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <!-- Driver ID Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DRIVER ID"
                    android:textColor="@color/login_text_gray"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:letterSpacing="0.05" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field">

                    <ImageView
                        android:id="@+id/icon_driver"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_id_card_new" />

                    <EditText
                        android:id="@+id/et_driver"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/icon_driver"
                        android:background="@null"
                        android:hint="Enter driver ID"
                        android:textColorHint="#94A3B8"
                        android:textColor="@color/login_text_dark"
                        android:textSize="16sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="16dp"
                        android:imeOptions="actionNext"
                        android:inputType="text"
                        android:singleLine="true"/>
                </RelativeLayout>

                <!-- Password Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textColor="@color/login_text_gray"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:letterSpacing="0.05" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field">

                    <ImageView
                        android:id="@+id/icon_pass"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_key_new" />

                    <EditText
                        android:id="@+id/et_pass"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/icon_pass"
                        android:layout_toStartOf="@+id/iv_pass_toggle"
                        android:background="@null"
                        android:hint="Enter password"
                        android:textColorHint="#94A3B8"
                        android:textColor="@color/login_text_dark"
                        android:textSize="16sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:singleLine="true"/>

                    <ImageView
                        android:id="@+id/iv_pass_toggle"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_alignParentEnd="true"
                        android:scaleType="center"
                        android:src="@drawable/ic_eye_outline"
                        android:contentDescription="Toggle visibility" />
                </RelativeLayout>

                <!-- Options Row -->
                <LinearLayout
                    android:id="@+id/forgotheader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <CheckBox
                        android:id="@+id/rememberme"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Remember this device"
                        android:textSize="13sp"
                        android:textColor="@color/login_text_dark"
                        android:buttonTint="@color/login_btn_gradient_start" />

                    <TextView
                        android:id="@+id/forgotpassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot password?"
                        android:textColor="@color/login_btn_gradient_start"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/sf_pro_display_regular"
                    android:text=""
                    android:textColor="@color/red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />

                <!-- Spinner -->
                <com.github.ybq.android.spinkit.SpinKitView
                    android:id="@+id/progress_bar"
                    style="@style/SpinKitView.ThreeBounce"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:SpinKit_Color="@color/login_btn_gradient_start" />

                <!-- Submit Button inside card -->
                <FrameLayout
                    android:id="@+id/submit"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_sign_in_button"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_right_white" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Sign In"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>