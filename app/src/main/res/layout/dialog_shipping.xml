<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Shipment"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1C1E" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set your current trip details"
            android:textSize="16sp"
            android:textColor="#44474E"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Shipping Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shipping Number *"
            android:textSize="14sp"
            android:textColor="#74777F"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#0061A4" />

            <EditText
                android:id="@+id/etShippingNumber"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Enter shipping number"
                android:inputType="text"
                android:paddingStart="12dp"
                android:textSize="16sp"
                android:textColor="#1A1C1E" />
        </LinearLayout>

        <!-- Co-driver -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Co-driver"
            android:textSize="14sp"
            android:textColor="#74777F"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvCoDriver"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No Co-driver"
                android:textSize="16sp"
                android:textColor="#1A1C1E" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                android:tint="#74777F" />
        </LinearLayout>

        <!-- Trailer Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trailer Number"
            android:textSize="14sp"
            android:textColor="#74777F"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_save"
                android:tint="#0061A4" />

            <EditText
                android:id="@+id/etTrailerNumber"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Enter trailer number"
                android:inputType="text"
                android:paddingStart="12dp"
                android:textSize="16sp"
                android:textColor="#1A1C1E" />
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#1A1C1E"
                android:backgroundTint="#F2F3F7"
                android:layout_marginEnd="8dp"
                app:cornerRadius="28dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Update"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#0061A4"
                android:layout_marginStart="8dp"
                app:cornerRadius="28dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
