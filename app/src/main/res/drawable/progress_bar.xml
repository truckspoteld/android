<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Layer -->
    <item>
        <clip>
            <shape>
                <solid android:color="@color/black" />
            </shape>
        </clip>
    </item>
    <!-- Progress Layer -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <solid android:color="#17f358" />
            </shape>
        </clip>
    </item>
</layer-list>
