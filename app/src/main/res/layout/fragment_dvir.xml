<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayoutDvir"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DVIR"
                android:textColor="@color/colorWhite"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Daily vehicle inspection report"
                android:textColor="@color/dark_text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/dark_card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/dark_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <Spinner
                        android:id="@+id/spinnerTripType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/drawable_light_black_rectangle_border"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/etOdometer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/colorWhite"
                        android:hint="Odometer"
                        android:inputType="number"
                        android:textColor="@color/colorWhite"
                        android:textColorHint="@color/dark_text_hint" />

                    <EditText
                        android:id="@+id/etTrailer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/colorWhite"
                        android:hint="Trailer number (optional)"
                        android:textColor="@color/colorWhite"
                        android:textColorHint="@color/dark_text_hint" />

                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/colorWhite"
                        android:hint="Location"
                        android:textColor="@color/colorWhite"
                        android:textColorHint="@color/dark_text_hint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Checklist"
                        android:textColor="@color/colorWhite"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbBrakes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brakes"
                        android:textColor="@color/colorWhite" />

                    <CheckBox
                        android:id="@+id/cbLights"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lights"
                        android:textColor="@color/colorWhite" />

                    <CheckBox
                        android:id="@+id/cbTires"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tires"
                        android:textColor="@color/colorWhite" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Vehicle condition"
                        android:textColor="@color/colorWhite"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgCondition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbSatisfactory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Satisfactory"
                            android:textColor="@color/colorWhite" />

                        <RadioButton
                            android:id="@+id/rbDefects"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:text="Has defects"
                            android:textColor="@color/colorWhite" />
                    </RadioGroup>

                    <EditText
                        android:id="@+id/etDefects"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/colorWhite"
                        android:gravity="top"
                        android:hint="Describe defects"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:textColor="@color/colorWhite"
                        android:textColorHint="@color/dark_text_hint"
                        android:visibility="gone" />

                    <CheckBox
                        android:id="@+id/cbSafeToOperate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:checked="true"
                        android:text="Safe to operate"
                        android:textColor="@color/colorWhite" />

                    <EditText
                        android:id="@+id/etSignature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/colorWhite"
                        android:hint="Driver signature (type full name)"
                        android:textColor="@color/colorWhite"
                        android:textColorHint="@color/dark_text_hint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitDvir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Submit DVIR"
                        app:backgroundTint="@color/dark_progress_green" />

                    <ProgressBar
                        android:id="@+id/progressSubmit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Recent DVIR"
                android:textColor="@color/colorWhite"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDvirHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
