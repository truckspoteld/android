<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#F2F2F7"
    app:cardCornerRadius="14dp"
    app:cardElevation="8dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#C6C6C8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:divider="@drawable/divider_horizontal_ios"
        android:showDividers="middle">

        <TextView
            android:id="@+id/sb1"
            style="@style/IosMenuItemStyle"
            android:text="Pre-Trip" />

        <TextView
            android:id="@+id/sb2"
            style="@style/IosMenuItemStyle"
            android:text="DOT Inspection" />

        <TextView
            android:id="@+id/sb3"
            style="@style/IosMenuItemStyle"
            android:text="Fueling" />

        <TextView
            android:id="@+id/sb4"
            style="@style/IosMenuItemStyle"
            android:text="Loading" />

        <TextView
            android:id="@+id/sb5"
            style="@style/IosMenuItemStyle"
            android:text="Un-Loading" />

        <TextView
            android:id="@+id/sb6"
            style="@style/IosMenuItemStyle"
            android:text="Pre-Trip and unloading" />

        <TextView
            android:id="@+id/sb7"
            style="@style/IosMenuItemStyle"
            android:text="Pre-Trip and Loading" />

        <TextView
            android:id="@+id/sb8"
            style="@style/IosMenuItemStyle"
            android:text="Pre-Trip and Fueling" />

        <TextView
            android:id="@+id/sb9"
            style="@style/IosMenuItemStyle"
            android:text="Hooking" />

        <TextView
            android:id="@+id/sb10"
            style="@style/IosMenuItemStyle"
            android:text="Dropping" />

        <TextView
            android:id="@+id/sb11"
            style="@style/IosMenuItemStyle"
            android:text="Repairing" />

        <TextView
            android:id="@+id/sb12"
            style="@style/IosMenuItemStyle"
            android:text="Border-Crossing" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
